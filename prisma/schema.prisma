generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  discordId    String     @unique
  username     String
  globalName   String?
  avatar       String?
  avatarUrl    String?
  nickname     String?
  roleIds      Json?
  isMember     Boolean    @default(false)
  isCommander  Boolean    @default(false)
  rankName     String?
  rankLevel    Int?
  divisionCode String?
  divisionName String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastLoginAt  DateTime?
  sessions     Session[]
  soldier      Soldier?
  issuedAwards Award[]    @relation("AwardIssuer")
  issuedWarnings Warning[] @relation("WarningIssuer")
  auditLogs    AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Soldier {
  id            String    @id @default(cuid())
  userId        String?   @unique
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  rankId        Int?
  division      String?
  position      String?
  discord       String?
  status        String    @default("В СТРОЮ")
  warningsCount Int       @default(0)
  joinDate      DateTime?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  awards        Award[]
  warnings      Warning[]
  auditLogs     AuditLog[]

  @@index([userId])
  @@index([division])
  @@index([rankId])
}

model Award {
  id             String   @id @default(cuid())
  soldierId       String
  soldier         Soldier  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  icon            String?
  color           String?
  issuedByUserId  String?
  issuedByUser    User?    @relation("AwardIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([soldierId])
  @@index([issuedByUserId])
}

model Warning {
  id             String   @id @default(cuid())
  soldierId      String
  soldier        Soldier  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  type           String
  reason         String
  issuedByUserId String?
  issuedByUser   User?    @relation("WarningIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([soldierId])
  @@index([issuedByUserId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  soldierId   String?
  soldier     Soldier? @relation(fields: [soldierId], references: [id], onDelete: SetNull)
  action      String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([soldierId])
  @@index([action])
}
